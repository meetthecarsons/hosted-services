# Environment file for Jellyfin stack (tracked in repo)
# Adjust values as required for the host.
# user/group IDs used by linuxserver images
PUID=1000
PGID=1000
# timezone
TZ=America/Los_Angeles
# host paths for Jellyfin data (replace with your own mount points)
JELLYFIN_CONFIG=/mnt/fast-pool-01/appdata/jellyfin/config
JELLYFIN_CACHE=/mnt/fast-pool-01/appdata/jellyfin/cache
JELLYFIN_MEDIA=/mnt/bulk-pool-01/data/media
# Port mapping for direct LAN access (update if you want a different host port)
JELLYFIN_PORT=8096
